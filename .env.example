# ── Bright Data credentials ────────────────────────────────────────────────────
# Get your API token at: https://docs.brightdata.jp/general/account/account-settings#api-token
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here

# Find your Web Scraper ID in the Bright Data Control Panel → Web Scrapers
# https://brightdata.jp/cp/scrapers
BRIGHTDATA_DATASET_ID=your_scraper_id_here
